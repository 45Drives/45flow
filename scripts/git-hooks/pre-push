#!/usr/bin/env bash
set -euo pipefail

# ── Selective upstream sync for 45flow-premium-dev ──────────────────────────
#
# Instead of merging ALL commits from studio-share, this hook only cherry-picks
# commits whose message starts with "downstream:" (case-insensitive).
#
# Workflow:
#   In studio-share, commit normally for free-only changes:
#     git commit -m "fix: some free-only bug"           ← ignored by premium
#
#   For changes that should propagate to premium:
#     git commit -m "downstream: fix transfer progress"  ← picked up automatically
#
# The hook runs on every push from 45flow-premium-dev. It:
#   1. Fetches upstream (studio-share)
#   2. Finds unmerged commits tagged with "downstream:"
#   3. Cherry-picks them into premium (stops on conflict for manual resolution)
#   4. Reports what it did
#
# To skip the hook in an emergency:  git push --no-verify

UPSTREAM_REMOTE="upstream"
UPSTREAM_URL="git@github.com:45Drives/studio-share.git"
UPSTREAM_BRANCH="community-edition"
SYNC_PREFIX="downstream:"
# File that tracks the last upstream commit we've scanned up to
SYNC_MARKER=".git/upstream-sync-marker"

echo "🔄 Checking studio-share upstream for 'downstream:' commits..."

# ── Ensure upstream remote exists ───────────────────────────────────────────
if ! git remote get-url "$UPSTREAM_REMOTE" >/dev/null 2>&1; then
  echo "  Adding upstream remote: $UPSTREAM_URL"
  git remote add "$UPSTREAM_REMOTE" "$UPSTREAM_URL"
fi

git fetch "$UPSTREAM_REMOTE" "$UPSTREAM_BRANCH" --quiet

# ── Determine scan range ────────────────────────────────────────────────────
# We track where we last scanned to avoid re-processing old commits.
# On first run (no marker), we scan from the common ancestor.
UPSTREAM_HEAD=$(git rev-parse "$UPSTREAM_REMOTE/$UPSTREAM_BRANCH")

if [[ -f "$SYNC_MARKER" ]]; then
  LAST_SYNCED=$(cat "$SYNC_MARKER")
  # Validate the marker still exists in history
  if ! git cat-file -t "$LAST_SYNCED" >/dev/null 2>&1; then
    LAST_SYNCED=$(git merge-base HEAD "$UPSTREAM_HEAD" 2>/dev/null || echo "")
  fi
else
  # First run: start from where histories diverged
  LAST_SYNCED=$(git merge-base HEAD "$UPSTREAM_HEAD" 2>/dev/null || echo "")
fi

if [[ -z "$LAST_SYNCED" ]]; then
  echo "  ⚠ Could not determine sync starting point. Skipping upstream sync."
  echo "$UPSTREAM_HEAD" > "$SYNC_MARKER"
  exit 0
fi

if [[ "$LAST_SYNCED" == "$UPSTREAM_HEAD" ]]; then
  echo "  ✓ Already up to date with upstream. No new commits to scan."
  exit 0
fi

# ── Find downstream-tagged commits ──────────────────────────────────────────
# List commits from LAST_SYNCED..upstream/main whose subject starts with the prefix
# --no-merges: skip merge commits
# Oldest first so cherry-picks apply in order
mapfile -t CANDIDATES < <(
  git log --no-merges --format="%H %s" "$LAST_SYNCED..$UPSTREAM_HEAD" --reverse |
  grep -i "^[0-9a-f]\{40\} ${SYNC_PREFIX}" || true
)

TOTAL=${#CANDIDATES[@]}
UPSTREAM_TOTAL=$(git rev-list --count "$LAST_SYNCED..$UPSTREAM_HEAD" --no-merges)

echo "  Found $TOTAL downstream-tagged commit(s) out of $UPSTREAM_TOTAL new upstream commit(s)."

if [[ $TOTAL -eq 0 ]]; then
  # Nothing to cherry-pick — update marker and continue
  echo "$UPSTREAM_HEAD" > "$SYNC_MARKER"

  if [[ $UPSTREAM_TOTAL -gt 0 ]]; then
    echo ""
    echo "  ℹ  $UPSTREAM_TOTAL upstream commit(s) were skipped (no \"$SYNC_PREFIX\" prefix)."
    echo "     This is expected — only tagged commits sync to premium."
  fi

  echo "  ✓ Push continuing."
  exit 0
fi

# ── Cherry-pick each tagged commit ──────────────────────────────────────────
echo ""
echo "  Cherry-picking $TOTAL commit(s) into premium..."
echo ""

APPLIED=0
for entry in "${CANDIDATES[@]}"; do
  HASH="${entry%% *}"
  SUBJECT="${entry#* }"
  SHORT=$(git rev-parse --short "$HASH")

  # Check if this commit was already cherry-picked manually (by subject match)
  if git log --oneline -20 --grep="^${SUBJECT}$" | grep -q .; then
    echo "  [$((APPLIED + 1))/$TOTAL] $SHORT: Already applied, skipping"
    APPLIED=$((APPLIED + 1))
    echo "$HASH" > "$SYNC_MARKER"
    continue
  fi

  echo "  [$((APPLIED + 1))/$TOTAL] $SHORT: $SUBJECT"

  if ! git cherry-pick "$HASH" --no-edit 2>/dev/null; then
    echo ""
    echo "  ✖ Cherry-pick conflict on $SHORT!"
    echo ""
    echo "  To resolve:"
    echo "    1. Fix conflicts in your editor (VS Code)"
    echo "    2. Stage files: git add <resolved-files>  (or click + in VS Code)"
    echo "    3. DON'T COMMIT! Run: git cherry-pick --continue"
    echo "    4. git push  (hook will skip already-picked commits)"
    echo ""
    echo "  Or abort:"
    echo "    git cherry-pick --abort"
    echo ""
    exit 1
  fi

  APPLIED=$((APPLIED + 1))
  
  # Update marker after each successful cherry-pick
  # This way manual conflict resolutions won't be retried
  echo "$HASH" > "$SYNC_MARKER"
done

# ── Update marker and report ────────────────────────────────────────────────
echo "$UPSTREAM_HEAD" > "$SYNC_MARKER"

echo ""
echo "  ✓ Successfully cherry-picked $APPLIED commit(s) from studio-share."
echo "  ✓ Push continuing."